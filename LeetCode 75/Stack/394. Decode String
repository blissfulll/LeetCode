class Solution:

    def decodeString(self, s: str) -> str:
        
        # def rec(idx):
            
        stack = []
        
        for idx, char in enumerate(s):
            if char == "]":
                i = -1
                tmp_s = ""
                while not stack[-1] == "[":
                    tmp_s = stack[-1] + tmp_s
                    stack.pop()
                stack.pop()
                stack[-1] = int(stack[-1]) * tmp_s 
            elif char.isdigit():
                if len(stack) == 0:
                    stack.append(char)
                elif stack[-1].isdigit():
                    stack[-1] += char 
                else:
                    stack.append(char)
            else:
                stack.append(char)

        ans = ""
        for word in stack:
            ans += word

        return ans

