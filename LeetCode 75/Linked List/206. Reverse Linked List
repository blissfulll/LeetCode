# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def reverseList(self, head: Optional[ListNode]) -> Optional[ListNode]:
        # safe = []

        if not head:
            return head

        if not head.next:
            return head

        if not head.next.next:
            tmp = ListNode()
            tmp.val = head.next.val
            head.next = None
            tmp.next = head
            return tmp

        prev = ListNode()
        prev.val = head.val
        prev.next = None
        while head:
            head = head.next
            if not head:
                return tmp
            tmp = ListNode()
            tmp.val = head.val
            tmp.next = prev
            prev = tmp 
            
            
        # print(tmp.val)

        return tmp
